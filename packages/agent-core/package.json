{
  "name": "@deskcrew/agent-core",
  "version": "0.0.1",
  "private": true,
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --external @earendil-works/pi-coding-agent --external @earendil-works/pi-ai",
    "dev": "bun build ./src/index.ts --outdir ./dist --target bun --watch --external @earendil-works/pi-coding-agent --external @earendil-works/pi-ai",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@deskcrew/protocol": "workspace:*",
    "@deskcrew/types": "workspace:*",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "uuid": "^14.0.0"
  }
}
